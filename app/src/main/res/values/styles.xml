<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--TextView-->
    <style name="MediumTextView" parent="TextAppearance.AppCompat">
        <item name="android:textColor">@color/black</item>
        <item name="android:fontFamily">@font/sc_dream_4</item>
        <item name="android:textSize">17.5sp</item>
    </style>

    <style name="LargeTextView" parent="TextAppearance.AppCompat">
        <item name="android:textColor">@color/black</item>
        <item name="android:fontFamily">@font/sc_dream_6</item>
    </style>

    <style name="RegistrationTextView" parent="LargeTextView">
        <item name="android:textSize">17sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="RegistrationGrayTextView" parent="TextAppearance.AppCompat">
        <item name="android:textColor">@color/gray</item>
        <item name="android:fontFamily">@font/sc_dream_3</item>
        <item name="android:textSize">14.5sp</item>
    </style>

    <!--toobar-->
    <style name="BasicToolBar" parent="Widget.AppCompat.Toolbar">
        <item name="background">@color/white</item>
        <item name="minHeight">?attr/actionBarSize</item>
        <item name="theme">?attr/actionBarSize</item>
        <item name="elevation">4dp</item>
    </style>

    <!--MaterialButton-->
    <style name="BasicMaterialButton" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="backgroundTint">@color/skyblue</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="SmallMaterialButton" parent="BasicMaterialButton">
        <item name="fontFamily">@font/sc_dream_3</item>
        <item name="android:textSize">17sp</item>
    </style>

    <style name="MediumMaterialButton" parent="BasicMaterialButton">
        <item name="fontFamily">@font/sc_dream_4</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="LargeMaterialButton" parent="android:Widget.Material.Button">
        <item name="fontFamily">@font/sc_dream_6</item>
        <item name="android:textSize">17sp</item>
    </style>

    <!--EditText-->
    <style name="SingleLineEditText" parent="Widget.AppCompat.EditText">
        <item name="android:background">@drawable/background_round_white</item>
        <item name="android:fontFamily">@font/sc_dream_3</item>
        <item name="singleLine">true</item>
        <item name="android:textSize">14.5sp</item>
    </style>

    <!--Button-->
    <style name="BasicButton" parent="TextAppearance.AppCompat.Button">
        <item name="backgroundTint">@color/white</item>
    </style>

    <style name="FloatingActionButton" parent="BasicButton">
        <item name="android:fontFamily">@font/font_sc_dream_5</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">18sp</item>
        <item name="background">@color/white</item>
    </style>

    <style name="AddButton" parent="BasicButton">
        <item name="android:textColor">@color/light_dark_gray</item>
        <item name="textAllCaps">false</item>
        <item name="android:layout_margin">10dp</item>
        <item name="layout_constraintVertical_weight">1</item>
    </style>

</resources>
