<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="viewModel"
            type="com.thinlineit.ctrlf.page.editor.PageEditorViewModel" />
    </data>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

                <ScrollView
                    android:id="@+id/markdownEditContainer"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    tools:context=".page.PageEditFragment">
                    <EditText
                        android:id="@+id/markdownEdit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/label_markdown_edit"
                        android:fontFamily="@font/sc_dream_5"
                        android:inputType="textMultiLine|textCapSentences"
                        android:paddingLeft="8dp"
                        android:paddingRight="8dp"
                        android:paddingBottom="16dp"
                        android:text="@={viewModel.content}" />

                </ScrollView>

                <HorizontalScrollView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" >
                    <Button
                        android:id="@+id/headerText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@color/dark_blue"
                        android:text="@string/button_editor_header" />

                    <Button
                        android:id="@+id/boldText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@color/dark_blue"
                        android:text="@string/button_editor_bold" />

                    <Button
                        android:id="@+id/italicText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@color/dark_blue"
                        android:text="@string/button_editor_italic" />

                    <Button
                        android:id="@+id/quoteText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@color/dark_blue"
                        android:text="@string/button_editor_quote" />
                    <Button
                        android:id="@+id/codeText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@color/dark_blue"
                        android:text="@string/button_editor_code" />
                    <Button
                        android:id="@+id/link"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@color/dark_blue"
                        android:text="@string/button_editor_link" />
                    <Button
                        android:id="@+id/bulletedList"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@color/dark_blue"
                        android:text="@string/button_editor_bulleted" />
                        <Button
                            android:id="@+id/numberList"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@color/dark_blue"
                            android:text="@string/button_editor_number_list" />
                    </LinearLayout>
                </HorizontalScrollView>
    </RelativeLayout>
</layout>
