<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout
        android:id="@+id/toolbox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/scrollview">

        <ImageButton
            android:id="@+id/headerText"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@color/wild_sand"
            android:src="@drawable/icon_header" />

        <ImageButton
            android:id="@+id/boldText"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@color/wild_sand"
            android:src="@drawable/icon_bold" />

        <ImageButton
            android:id="@+id/italicText"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@color/wild_sand"
            android:src="@drawable/icon_italic" />

        <ImageButton
            android:id="@+id/bulletedList"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@color/wild_sand"
            android:src="@drawable/icon_bullet_list" />

        <ImageButton
            android:id="@+id/numberList"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@color/wild_sand"
            android:src="@drawable/icon_number_list" />

        <ImageButton
            android:id="@+id/codeText"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@color/wild_sand"
            android:src="@drawable/icon_code" />

        <ImageButton
            android:id="@+id/link"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@color/wild_sand"
            android:src="@drawable/icon_link" />

        <ImageButton
            android:id="@+id/image"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@color/wild_sand"
            android:src="@drawable/icon_image" />

        <ImageButton
            android:id="@+id/quoteText"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@color/wild_sand"
            android:text="@string/button_editor_quote" />
    </LinearLayout>
</merge>
